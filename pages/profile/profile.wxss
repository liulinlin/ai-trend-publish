/* pages/profile/profile.wxss */
.user-section {
  background: linear-gradient(135deg, #EB2F96 0%, #C41D7F 100%);
  padding: 60rpx 40rpx;
  display: flex;
  align-items: center;
  color: white;
}

.user-avatar {
  width: 120rpx;
  height: 120rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 60rpx;
  margin-right: 30rpx;
}

.user-info {
  flex: 1;
}

.user-name {
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
}

.user-desc {
  font-size: 28rpx;
  opacity: 0.9;
}

.stats-section {
  background: white;
  margin: 20rpx;
  border-radius: 16rpx;
  padding: 40rpx 20rpx;
  display: flex;
  justify-content: space-around;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}

.stat-item {
  text-align: center;
}

.stat-value {
  font-size: 48rpx;
  font-weight: bold;
  color: #EB2F96;
  margin-bottom: 10rpx;
}

.stat-label {
  font-size: 24rpx;
  color: #999;
}

.menu-section {
  background: white;
  margin: 20rpx;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon {
  font-size: 40rpx;
  margin-right: 20rpx;
}

.menu-text {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.menu-arrow {
  font-size: 28rpx;
  color: #d9d9d9;
}

.login-section {
  padding: 40rpx 20rpx;
}

.login-btn {
  background: #EB2F96;
  color: white;
  border-radius: 8rpx;
  font-size: 32rpx;
}

/* 额度卡片 */
.credits-card {
  background: white;
  margin: 20rpx;
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}

.credits-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.credits-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.credits-refresh {
  font-size: 28rpx;
  color: #EB2F96;
}

.credits-stats {
  display: flex;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 12rpx;
  padding: 24rpx;
}

.credit-stat {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.credit-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
  margin-bottom: 8rpx;
}

.credit-value {
  font-size: 36rpx;
  font-weight: bold;
  color: white;
}

.credit-divider {
  width: 2rpx;
  background: rgba(255, 255, 255, 0.3);
  margin: 0 20rpx;
}
