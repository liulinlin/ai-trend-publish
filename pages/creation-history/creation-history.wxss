/* pages/creation-history/creation-history.wxss */
.page-container {
  min-height: 100vh;
  background: #f5f5f5;
}

/* 顶部导航 */
.header-section {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  background: #fff;
  border-bottom: 1rpx solid #f0f0f0;
}

.header-content {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.back-btn {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background: #f5f5f5;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-btn .icon {
  font-size: 36rpx;
  color: #333;
}

.header-text {
  display: flex;
  flex-direction: column;
}

.page-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.page-subtitle {
  font-size: 24rpx;
  color: #999;
  margin-top: 4rpx;
}

.clear-btn {
  font-size: 28rpx;
  color: #ff6b6b;
  padding: 12rpx 24rpx;
}

/* 标签切换 */
.tabs {
  display: flex;
  background: #fff;
  padding: 20rpx 30rpx;
  gap: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  font-size: 28rpx;
  color: #666;
  border-radius: 12rpx;
  transition: all 0.3s;
}

.tab-item.active {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  font-weight: bold;
}

/* 历史记录列表 */
.history-list {
  height: calc(100vh - 240rpx);
  padding: 30rpx;
}

.history-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.type-badge {
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  background: #f0f0f0;
  color: #666;
}

.type-badge.article {
  background: rgba(102, 126, 234, 0.1);
  color: #667eea;
}

.type-badge.post {
  background: rgba(76, 175, 80, 0.1);
  color: #4caf50;
}

.type-badge.video-script {
  background: rgba(255, 107, 107, 0.1);
  color: #ff6b6b;
}

.status-badge {
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
}

.status-badge.completed {
  background: rgba(76, 175, 80, 0.1);
  color: #4caf50;
}

.status-badge.draft {
  background: rgba(255, 152, 0, 0.1);
  color: #ff9800;
}

.status-badge.published {
  background: rgba(33, 150, 243, 0.1);
  color: #2196f3;
}

.card-content {
  margin-bottom: 20rpx;
}

.hotspot-title {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
  line-height: 1.4;
}

.content-preview {
  display: block;
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.card-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 20rpx;
  border-top: 1rpx solid #f0f0f0;
}

.time {
  font-size: 22rpx;
  color: #999;
}

.actions {
  display: flex;
  gap: 24rpx;
}

.action-btn {
  font-size: 24rpx;
  color: #667eea;
  padding: 8rpx 20rpx;
  background: rgba(102, 126, 234, 0.1);
  border-radius: 20rpx;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
  gap: 30rpx;
}

.empty-icon {
  font-size: 120rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}

.start-btn {
  padding: 24rpx 60rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  border-radius: 40rpx;
  font-size: 28rpx;
  border: none;
}
