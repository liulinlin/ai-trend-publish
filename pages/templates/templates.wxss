/* pages/templates/templates.wxss */
.page-header {
  background: white;
  padding: 40rpx;
  text-align: center;
}

.page-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 10rpx;
}

.page-subtitle {
  font-size: 26rpx;
  color: #999;
}

.template-list {
  padding: 20rpx;
}

.template-card {
  background: white;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
  transition: all 0.3s;
}

.template-card:active {
  transform: scale(0.98);
}

.template-icon {
  font-size: 64rpx;
  margin-right: 24rpx;
}

.template-info {
  flex: 1;
}

.template-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.template-desc {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 12rpx;
}

.template-tags {
  display: flex;
  gap: 10rpx;
  flex-wrap: wrap;
}

.tag {
  background: #f9ecf2;
  color: #EB2F96;
  font-size: 22rpx;
  padding: 6rpx 12rpx;
  border-radius: 4rpx;
}

.template-use {
  background: #EB2F96;
  color: white;
  padding: 16rpx 24rpx;
  border-radius: 8rpx;
  font-size: 28rpx;
}

/* 热点选择对话框 */
.hotspot-dialog {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.hotspot-dialog-content {
  width: 90%;
  max-height: 80%;
  background: white;
  border-radius: 24rpx;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.hotspot-dialog-header {
  padding: 40rpx 30rpx 20rpx;
  text-align: center;
  border-bottom: 1rpx solid #f0f0f0;
}

.hotspot-dialog-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 10rpx;
}

.hotspot-dialog-subtitle {
  font-size: 26rpx;
  color: #999;
  display: block;
}

.hotspot-list {
  flex: 1;
  padding: 20rpx;
  max-height: 600rpx;
}

.hotspot-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  margin-bottom: 16rpx;
  background: #f8f9fa;
  border-radius: 16rpx;
  transition: all 0.3s;
}

.hotspot-item:active {
  background: #e8f4ff;
  transform: scale(0.98);
}

.hotspot-index {
  width: 56rpx;
  height: 56rpx;
  line-height: 56rpx;
  text-align: center;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  border-radius: 50%;
  font-weight: bold;
  font-size: 24rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.hotspot-content {
  flex: 1;
  min-width: 0;
}

.hotspot-name {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  display: block;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.hotspot-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.hotspot-source {
  font-size: 22rpx;
  color: #999;
  padding: 4rpx 12rpx;
  background: white;
  border-radius: 4rpx;
}

.hotspot-heat {
  font-size: 22rpx;
  color: #ff6b6b;
}

.hotspot-dialog-footer {
  padding: 20rpx 30rpx 30rpx;
  border-top: 1rpx solid #f0f0f0;
}

.skip-btn {
  width: 100%;
  background: #f5f5f5;
  color: #666;
  border-radius: 12rpx;
  font-size: 28rpx;
  padding: 24rpx;
  border: none;
}

.skip-btn::after {
  border: none;
}
