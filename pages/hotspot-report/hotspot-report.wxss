/* pages/hotspot-report/hotspot-report.wxss */
.report-container {
  min-height: 100vh;
  background: #F5F3FF;
  padding-bottom: 120rpx;
}

/* 加载状态 */
.loading {
  padding: 200rpx 0;
  text-align: center;
}

.loading-text {
  font-size: 28rpx;
  color: #9CA3AF;
}

/* 报告内容 */
.report-content {
  padding: 20rpx;
}

/* 报告标题 */
.report-header {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 32rpx 24rpx;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(102, 126, 234, 0.3);
}

.report-title {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: white;
  margin-bottom: 12rpx;
}

.report-time {
  display: block;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* 报告区块 */
.report-section {
  background: white;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.section-title {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 2rpx solid #E5E7EB;
}

.title-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.title-text {
  font-size: 28rpx;
  font-weight: 600;
  color: #1F2937;
}

.section-subtitle {
  display: block;
  font-size: 24rpx;
  color: #6B7280;
  margin-bottom: 12rpx;
}

/* 摘要卡片 */
.summary-grid {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.summary-card {
  flex: 1;
  background: linear-gradient(135deg, #A855F7 0%, #EC4899 100%);
  padding: 20rpx;
  border-radius: 12rpx;
  text-align: center;
}

.summary-label {
  display: block;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.9);
  margin-bottom: 8rpx;
}

.summary-value {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  color: white;
  line-height: 1.2;
}

.summary-unit {
  display: block;
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 4rpx;
}

/* 关键词云 */
.keywords-cloud {
  padding: 16rpx;
  background: #F9FAFB;
  border-radius: 12rpx;
}

.keywords-list {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.keyword-tag {
  display: inline-block;
  padding: 6rpx 16rpx;
  background: white;
  color: #A855F7;
  font-size: 22rpx;
  border-radius: 16rpx;
  border: 1rpx solid #E9D5FF;
}

/* 洞察卡片 */
.insight-card {
  padding: 16rpx;
  background: #F9FAFB;
  border-radius: 12rpx;
  margin-bottom: 12rpx;
}

.insight-label {
  display: block;
  font-size: 24rpx;
  font-weight: 600;
  color: #374151;
  margin-bottom: 8rpx;
}

.insight-content {
  display: block;
  font-size: 24rpx;
  color: #6B7280;
  line-height: 1.6;
}

/* 需求列表 */
.needs-list {
  padding: 16rpx;
  background: #F9FAFB;
  border-radius: 12rpx;
}

.need-item {
  display: flex;
  align-items: flex-start;
  margin-bottom: 12rpx;
}

.need-item:last-child {
  margin-bottom: 0;
}

.need-dot {
  font-size: 24rpx;
  color: #A855F7;
  margin-right: 8rpx;
  flex-shrink: 0;
}

.need-text {
  flex: 1;
  font-size: 24rpx;
  color: #374151;
  line-height: 1.5;
}

/* 痛点金字塔 */
.painpoint-pyramid {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.pyramid-level {
  border-radius: 12rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

.level-header {
  padding: 12rpx 16rpx;
}

.level-title {
  font-size: 24rpx;
  font-weight: 600;
  color: white;
}

.level-content {
  padding: 16rpx;
  background: #F9FAFB;
}

.level-point {
  display: block;
  font-size: 22rpx;
  color: #374151;
  line-height: 1.6;
  margin-bottom: 8rpx;
}

.level-point:last-child {
  margin-bottom: 0;
}

/* 预测标签 */
.prediction-tabs {
  display: flex;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.prediction-tabs .tab {
  flex: 1;
  padding: 12rpx;
  background: #F3F4F6;
  border-radius: 12rpx;
  text-align: center;
  font-size: 22rpx;
  color: #6B7280;
  transition: all 0.3s ease;
}

.prediction-tabs .tab.active {
  background: linear-gradient(135deg, #A855F7 0%, #EC4899 100%);
  color: white;
  font-weight: 600;
}

/* 预测内容 */
.prediction-content {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.prediction-block {
  padding: 16rpx;
  background: #F9FAFB;
  border-radius: 12rpx;
}

.prediction-label {
  display: block;
  font-size: 24rpx;
  font-weight: 600;
  color: #374151;
  margin-bottom: 12rpx;
}

.prediction-list {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.prediction-item {
  display: block;
  font-size: 22rpx;
  color: #6B7280;
  line-height: 1.6;
}

/* 建议卡片 */
.recommendation-card {
  padding: 20rpx;
  background: #F9FAFB;
  border-radius: 12rpx;
  margin-bottom: 12rpx;
}

.recommendation-card:last-child {
  margin-bottom: 0;
}

.card-header {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.card-icon {
  font-size: 28rpx;
  margin-right: 8rpx;
}

.card-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #1F2937;
}

.card-content {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.recommendation-item {
  display: block;
  font-size: 22rpx;
  color: #374151;
  line-height: 1.6;
}

/* 底部操作 */
.report-actions {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx;
  background: white;
  border-top: 1rpx solid #E5E7EB;
  display: flex;
  gap: 16rpx;
  box-shadow: 0 -2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.action-btn {
  flex: 1;
  height: 80rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: 600;
  border: none;
}

.action-btn::after {
  border: none;
}

.action-btn.secondary {
  background: #F3F4F6;
  color: #6B7280;
}

.action-btn.primary {
  background: linear-gradient(135deg, #A855F7 0%, #EC4899 100%);
  color: white;
  box-shadow: 0 4rpx 12rpx rgba(168, 85, 247, 0.3);
}
