/* pages/agent-ui/agent-ui.wxss */
.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #f5f5f5;
  padding: 20rpx;
}

/* 顶部提示 */
.header-tip {
  background: rgba(7, 193, 96, 0.1);
  border: 1px solid rgba(7, 193, 96, 0.3);
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  position: relative;
}

.tip-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.tip-text {
  color: #07c160;
  font-size: 28rpx;
  font-weight: 500;
  flex: 1;
}

.config-btn {
  background: #EB2F96;
  color: white;
  font-size: 24rpx;
  padding: 12rpx 24rpx;
  border-radius: 8rpx;
  border: none;
  margin-left: 16rpx;
}

.config-btn:active {
  opacity: 0.8;
}

/* Agent-UI 容器 */
.agent-ui-container {
  flex: 1;
  background: white;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

/* 占位内容 */
.placeholder-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
}

.placeholder-title {
  font-size: 32rpx;
  color: #333;
  margin-bottom: 16rpx;
}

.placeholder-desc {
  font-size: 28rpx;
  color: #999;
}

/* 聊天容器 */
.chat-container {
  flex: 1;
  display: flex;
  flex-direction: column;
  height: 100%;
}

/* 消息列表 */
.message-list {
  flex: 1;
  padding: 20rpx;
  background: #fafafa;
}

.message-item {
  margin-bottom: 24rpx;
  display: flex;
  flex-direction: column;
}

.message-bubble {
  max-width: 80%;
  padding: 20rpx;
  border-radius: 12rpx;
  word-wrap: break-word;
  word-break: break-all;
}

.message-bubble.user {
  align-self: flex-end;
  background: #07c160;
  color: white;
  border-bottom-right-radius: 4rpx;
}

.message-bubble.assistant {
  align-self: flex-start;
  background: white;
  color: #333;
  border: 1px solid #e0e0e0;
  border-bottom-left-radius: 4rpx;
}

.message-bubble.system {
  align-self: center;
  background: rgba(255, 152, 0, 0.1);
  color: #ff9800;
  border: 1px solid rgba(255, 152, 0, 0.3);
  font-size: 24rpx;
  max-width: 90%;
  text-align: center;
}

.message-text {
  font-size: 28rpx;
  line-height: 1.5;
}

/* 正在输入状态 */
.typing-indicator {
  padding: 20rpx;
  text-align: center;
}

.typing-text {
  font-size: 24rpx;
  color: #999;
}

/* 输入区域 */
.input-area {
  display: flex;
  padding: 20rpx;
  background: white;
  border-top: 1px solid #e0e0e0;
  align-items: center;
}

.input-box {
  flex: 1;
  height: 80rpx;
  background: #f5f5f5;
  border-radius: 40rpx;
  padding: 0 30rpx;
  font-size: 28rpx;
  margin-right: 20rpx;
}

.send-btn {
  height: 80rpx;
  padding: 0 40rpx;
  background: #ccc;
  color: white;
  border-radius: 40rpx;
  font-size: 28rpx;
  line-height: 80rpx;
  transition: all 0.3s;
}

.send-btn.active {
  background: #07c160;
}

.send-btn:active {
  opacity: 0.8;
}

/* 底部说明 */
.footer-note {
  margin-top: 20rpx;
  padding: 20rpx;
  background: rgba(235, 47, 150, 0.1);
  border-radius: 12rpx;
}

.note-title {
  display: block;
  font-size: 24rpx;
  color: #EB2F96;
  font-weight: 500;
  margin-bottom: 8rpx;
}

.note-content {
  font-size: 24rpx;
  color: #666;
  line-height: 1.5;
}

/* 配置信息 */
.config-info {
  margin-top: 20rpx;
  padding: 20rpx;
  background: white;
  border-radius: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.config-title {
  display: block;
  font-size: 26rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 12rpx;
}

.config-item {
  display: block;
  font-size: 24rpx;
  color: #666;
  margin-bottom: 8rpx;
  word-break: break-all;
}

.config-item.status {
  font-weight: 500;
  margin-top: 12rpx;
}

.config-item.status.success {
  color: #07c160;
}

.config-item.status.warning {
  color: #ff9800;
}

/* 加载动画 */
@keyframes pulse {
  0% { opacity: 0.6; }
  50% { opacity: 1; }
  100% { opacity: 0.6; }
}

.loading {
  animation: pulse 1.5s infinite;
}
