/* pages/index/index.wxss - 简化可用版本 */

/* 🔧 诊断工具按钮 - 临时使用，调试后可删除 */
.force-close-btn {
  position: fixed;
  top: 80rpx;
  left: 20rpx;
  z-index: 1000;
  background: #ff6b6b;
  color: white;
  font-size: 24rpx;
  padding: 12rpx 24rpx;
  border-radius: 12rpx;
  border: 2px solid #ff4444;
  box-shadow: 0 4rpx 12rpx rgba(255, 107, 107, 0.5);
}

.test-click-btn {
  position: fixed;
  top: 140rpx;
  left: 20rpx;
  z-index: 999;
  background: #4CAF50;
  color: white;
  font-size: 24rpx;
  padding: 12rpx 24rpx;
  border-radius: 12rpx;
  border: 2px solid #388E3C;
  box-shadow: 0 4rpx 12rpx rgba(76, 175, 80, 0.5);
}

/* 🔒 确保页面容器可点击 */
.page-container {
  background: #F5F3FF;
  min-height: 100vh;
  padding-bottom: 160rpx;
  position: relative;
  z-index: 1;
}

/* 🚨 强制确保所有可点击元素在最上层 */
.main-section {
  pointer-events: auto !important;
}

.input-box {
  pointer-events: auto !important;
}

.input-footer {
  pointer-events: auto !important;
}

.create-btn {
  pointer-events: auto !important;
}

.quick-functions {
  pointer-events: auto !important;
}

.function-btn {
  pointer-events: auto !important;
}

/* 🔒 恢复header-section的点击事件，移除过度限制 */
.header-section {
  pointer-events: auto !important;
}

.header-content {
  pointer-events: auto !important;
}

.header-actions {
  pointer-events: auto !important;
}

/* 顶部区域 */
.header-section {
  background: linear-gradient(135deg, #A855F7 0%, #EC4899 100%);
  padding: 40rpx 32rpx 32rpx;
  border-radius: 0 0 40rpx 40rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.header-content {
  display: flex;
  align-items: center;
  gap: 24rpx;
  flex: 1;
}

.header-actions {
  display: flex;
  gap: 12rpx;
  align-items: center;
  position: relative;
  z-index: 10;
}

.app-icon {
  font-size: 56rpx;
  line-height: 1;
}

.header-text {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.app-title {
  font-size: 36rpx;
  font-weight: bold;
  color: white;
  line-height: 1.2;
}

.app-subtitle {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.9);
  line-height: 1.2;
}

/* 积分显示 */
.credits-display {
  display: flex;
  gap: 8rpx;
  background: rgba(255, 255, 255, 0.2);
  padding: 8rpx 16rpx;
  border-radius: 30rpx;
  backdrop-filter: blur(10rpx);
}

.credits-item {
  display: flex;
  align-items: center;
  gap: 4rpx;
}

.credits-icon {
  font-size: 24rpx;
}

.credits-value {
  font-size: 24rpx;
  color: white;
  font-weight: 600;
}

.icon-btn {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  backdrop-filter: blur(10rpx);
}

.icon {
  font-size: 28rpx;
  color: white;
}

/* 主要创作区域 - 提升层级 */
.main-section {
  margin: 24rpx 20rpx;
  position: relative;
  z-index: 100;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #1F2937;
  margin-bottom: 16rpx;
}

/* 输入框 - 提升层级 */
.input-box {
  background: white;
  border-radius: 16rpx;
  padding: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
  position: relative;
  z-index: 101;
}

.input-textarea {
  width: 100%;
  min-height: 100rpx;
  max-height: 300rpx;
  font-size: 28rpx;
  line-height: 1.6;
  color: #1F2937;
  padding: 16rpx;
  background: #F9FAFB;
  border-radius: 12rpx;
  border: 2rpx solid #E5E7EB;
  transition: all 0.3s ease;
}

.input-textarea:focus {
  border-color: #A855F7;
  background: white;
}

.input-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 16rpx;
  position: relative;
  z-index: 102;
}

.char-count {
  font-size: 22rpx;
  color: #9CA3AF;
}

.create-btn {
  background: linear-gradient(135deg, #A855F7 0%, #EC4899 100%);
  color: #FFFFFF !important;
  border: none;
  border-radius: 24rpx;
  padding: 16rpx 40rpx;
  font-size: 28rpx;
  font-weight: 600;
  box-shadow: 0 4rpx 12rpx rgba(168, 85, 247, 0.3);
  position: relative;
  z-index: 103;
}

.create-btn[disabled] {
  opacity: 0.7;
  box-shadow: none;
  background: #CBD5E1;
  color: #9CA3AF !important;
  pointer-events: none;
}

.create-btn::after {
  border: none;
}

/* 快捷功能 - 提升层级 */
.quick-functions {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 12rpx;
  margin-top: 16rpx;
  position: relative;
  z-index: 104;
}

.function-btn {
  background: white;
  border-radius: 12rpx;
  padding: 20rpx 12rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
  position: relative;
  z-index: 105 !important;
  pointer-events: auto !important;
  cursor: pointer;
}

.btn-icon {
  font-size: 40rpx;
}

.btn-text {
  font-size: 22rpx;
  color: #6B7280;
  text-align: center;
}

/* 热点横幅 */
.hotspot-banner {
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E53 100%);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 32rpx;  /* 🔧 增加底部间距，避免挤压下方按钮 */
  display: flex;
  align-items: center;
  gap: 16rpx;
  box-shadow: 0 4rpx 12rpx rgba(255, 107, 107, 0.3);
  position: relative;
  z-index: 5;
  /* animation: pulse 2s ease-in-out infinite;  🔒 禁用动画修复点击不稳定问题 */
}

@keyframes pulse {
  0%, 100% {
    transform: scale(1);
  }
  50% {
    transform: scale(1.02);
  }
}

.banner-icon {
  font-size: 48rpx;
  /* animation: bounce 1s ease-in-out infinite;  🔒 禁用动画修复点击不稳定问题 */
}

@keyframes bounce {
  0%, 100% {
    transform: translateY(0);
  }
  50% {
    transform: translateY(-8rpx);
  }
}

.banner-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.banner-title {
  font-size: 30rpx;
  font-weight: bold;
  color: white;
}

.banner-desc {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
}

.banner-arrow {
  font-size: 32rpx;
  color: white;
  font-weight: bold;
}

/* 灵感区域 */
.inspiration-section {
  margin: 24rpx 20rpx;
  position: relative;
  z-index: 10;
}

.section-header {
  margin-bottom: 16rpx;
}

.inspiration-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
}

.inspiration-card {
  background: white;
  border-radius: 12rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.card-cover {
  position: relative;
  width: 100%;
  height: 200rpx;
  background: #F3F4F6;
}

.cover-image {
  width: 100%;
  height: 100%;
}

.card-play-btn {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.6);
  display: flex;
  align-items: center;
  justify-content: center;
}

.play-icon {
  font-size: 24rpx;
  color: white;
}

.card-info {
  padding: 16rpx;
}

.card-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #1F2937;
  display: block;
  margin-bottom: 4rpx;
}

.card-desc {
  font-size: 22rpx;
  color: #6B7280;
  display: block;
}

.hidden-video {
  display: none;
}

/* 确保按钮可点击 - 最高优先级 */
.function-btn {
  background: white;
  border-radius: 12rpx;
  padding: 20rpx 12rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
  position: relative;
  z-index: 1000 !important;
  pointer-events: auto !important;
}

/* 抽屉 - 降低层级避免遮挡 */
.drawer-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 40;
}

.drawer-content {
  position: fixed;
  right: -100%;
  top: 0;
  bottom: 0;
  width: 80%;
  max-width: 600rpx;
  background: white;
  z-index: 51;
  transition: right 0.3s ease;
  display: flex;
  flex-direction: column;
}

.drawer-content.show {
  right: 0;
}





.drawer-header {
  padding: 32rpx 24rpx;
  border-bottom: 1rpx solid #E5E7EB;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.drawer-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #1F2937;
}

.drawer-close {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #6B7280;
}

.drawer-body {
  flex: 1;
  overflow-y: auto;
  padding: 24rpx;
}

.drawer-group {
  margin-bottom: 32rpx;
}

.group-title {
  font-size: 24rpx;
  color: #9CA3AF;
  margin-bottom: 16rpx;
  padding-left: 8rpx;
}

.drawer-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 16rpx;
  border-radius: 12rpx;
  margin-bottom: 8rpx;
  background: #F9FAFB;
}

.item-icon-box {
  width: 64rpx;
  height: 64rpx;
  border-radius: 12rpx;
  background: linear-gradient(135deg, #A855F7 0%, #EC4899 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  flex-shrink: 0;
}

.item-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.item-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1F2937;
}

.item-desc {
  font-size: 22rpx;
  color: #6B7280;
}



/* 灵感区域 - 改为热点展示 */
.inspiration-section {
  margin: 24rpx 20rpx;
  position: relative;
  z-index: 10;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.section-title-group {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.section-subtitle {
  font-size: 22rpx;
  color: #9CA3AF;
}

.header-actions {
  display: flex;
  gap: 12rpx;
  align-items: center;
}

.refresh-btn {
  display: flex;
  align-items: center;
  gap: 4rpx;
  padding: 8rpx 16rpx;
  background: white;
  border-radius: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.refresh-icon {
  font-size: 24rpx;
}

.refresh-text {
  font-size: 22rpx;
  color: #6B7280;
}

.view-all-btn {
  font-size: 22rpx;
  color: #A855F7;
  font-weight: 600;
}

/* 分类标签 */
.category-tabs {
  display: flex;
  white-space: nowrap;
  margin-bottom: 16rpx;
  padding: 8rpx 0;
  gap: 12rpx;
}

.category-tab {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 16rpx 28rpx;
  background: white;
  border-radius: 28rpx;
  font-size: 26rpx;
  color: #6B7280;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
  transition: all 0.3s ease;
  cursor: pointer;
  min-width: 100rpx;
  text-align: center;
}

.category-tab:active {
  transform: scale(0.95);
  box-shadow: 0 1rpx 4rpx rgba(0, 0, 0, 0.1);
}

.category-tab.active {
  background: linear-gradient(135deg, #A855F7 0%, #EC4899 100%);
  color: white;
  font-weight: 600;
  box-shadow: 0 4rpx 12rpx rgba(168, 85, 247, 0.3);
}

/* 热点列表 */
.hotspot-list {
  min-height: 200rpx;
}

.hotspot-ticker {
  display: flex;
  white-space: nowrap;
  overflow-x: auto;
  gap: 12rpx;
  padding: 8rpx 0;
}

/* 新增：网格布局 - 改为一列 */
.hotspot-grid {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  padding: 8rpx 0;
}

.hotspot-card {
  background: white;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
  position: relative;
  transition: all 0.3s ease;
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.hotspot-card:active {
  transform: scale(0.98);
  box-shadow: 0 1rpx 4rpx rgba(0, 0, 0, 0.1);
  background: #f9fafb;
}

.hotspot-rank {
  flex-shrink: 0;
  width: 48rpx;
  height: 48rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: white;
  font-size: 24rpx;
  font-weight: bold;
  box-shadow: 0 2rpx 8rpx rgba(102, 126, 234, 0.3);
}

.hotspot-content {
  flex: 1;
  min-width: 0;
}

.hotspot-card .hotspot-title {
  font-size: 28rpx;
  color: #1f2937;
  font-weight: 500;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  line-height: 1.6;
  margin-bottom: 12rpx;
}

.hotspot-tags {
  display: flex;
  gap: 8rpx;
  margin-bottom: 12rpx;
  flex-wrap: wrap;
}

.tag {
  font-size: 20rpx;
  color: #A855F7;
  background: #F3F4F6;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
}

.hotspot-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #1F2937;
  display: block;
  margin-bottom: 8rpx;
  line-height: 1.4;
}

.hotspot-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 12rpx;
  flex-wrap: wrap;
}

.source-tag {
  font-size: 22rpx;
  color: #6B7280;
  background: #F3F4F6;
  padding: 6rpx 16rpx;
  border-radius: 12rpx;
  font-weight: 500;
}

.heat-value {
  font-size: 24rpx;
  color: #EF4444;
  font-weight: 600;
  white-space: nowrap;
}

/* 查看更多按钮 */
.view-more-section {
  margin-top: 24rpx;
  text-align: center;
}

.view-more-btn {
  background: linear-gradient(135deg, #A855F7 0%, #EC4899 100%);
  color: white;
  border: none;
  border-radius: 28rpx;
  padding: 20rpx 40rpx;
  font-size: 28rpx;
  font-weight: 600;
  box-shadow: 0 4rpx 12rpx rgba(168, 85, 247, 0.3);
}

.view-more-btn::after {
  border: none;
}

.use-btn {
  position: absolute;
  bottom: 20rpx;
  right: 20rpx;
  padding: 8rpx 20rpx;
  background: linear-gradient(135deg, #A855F7 0%, #EC4899 100%);
  color: white;
  border-radius: 20rpx;
  font-size: 22rpx;
  font-weight: 600;
}

/* 分类热点项 */
.hotspot-item {
  background: white;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.hotspot-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.hotspot-desc {
  font-size: 24rpx;
  color: #6B7280;
  line-height: 1.5;
  display: block;
  margin-bottom: 12rpx;
}

.hotspot-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.source-text {
  font-size: 22rpx;
  color: #9CA3AF;
}

.use-text {
  font-size: 22rpx;
  color: #A855F7;
  font-weight: 600;
}

/* 空状态 */
.empty-hotspot {
  text-align: center;
  padding: 60rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  display: block;
  margin-bottom: 16rpx;
}

.empty-text {
  font-size: 24rpx;
  color: #9CA3AF;
  display: block;
}

/* 加载状态 */
.loading-hotspot {
  text-align: center;
  padding: 60rpx 0;
}

.loading-icon {
  font-size: 60rpx;
  display: block;
  animation: spin 1s linear infinite;
}

.loading-text {
  font-size: 24rpx;
  color: #9CA3AF;
  display: block;
  margin-top: 16rpx;
}

@keyframes spin {
  0% {
    transform: rotate(0deg);
  }
  100% {
    transform: rotate(360deg);
  }
}

/* 创意建议区域 */
.suggestion-section {
  margin-top: 32rpx;
}

.suggestion-header {
  margin-bottom: 16rpx;
}

.suggestion-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1F2937;
}

.suggestion-scroll {
  display: flex;
  white-space: nowrap;
  overflow-x: auto;
  gap: 12rpx;
  padding: 8rpx 0;
}

.suggestion-card {
  display: inline-block;
  min-width: 260rpx;
  background: white;
  border-radius: 16rpx;
  padding: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
  display: flex;
  gap: 12rpx;
}

.suggestion-icon {
  font-size: 48rpx;
  flex-shrink: 0;
}

.suggestion-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.suggestion-title {
  font-size: 24rpx;
  font-weight: 600;
  color: #1F2937;
}

.suggestion-desc {
  font-size: 20rpx;
  color: #6B7280;
  line-height: 1.4;
}

.suggestion-tags {
  display: flex;
  gap: 6rpx;
  flex-wrap: wrap;
}

.suggestion-tags .tag {
  font-size: 18rpx;
}

/* 🔧 测试完成，移除测试样式 */
