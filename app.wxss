/**app.wxss**/
page {
  background-color: #f5f5f5;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Roboto', 'Oxygen', 'Ubuntu', 'Cantarell', 'Fira Sans', 'Droid Sans', 'Helvetica Neue', sans-serif;
}

/* 🔒 移除全局 pointer-events，让小程序默认处理 */
/* button { pointer-events: auto; } */

/* 🔒 确保没有隐藏的遮罩层遮挡 */
.fixed-mask-hidden {
  display: none !important;
  pointer-events: none !important;
}

.container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: 100rpx;
}

/* 通用样式 */
.btn-primary {
  background: #EB2F96;
  color: white;
  border-radius: 24rpx;
  padding: 32rpx 48rpx;
  font-size: 32rpx;
  min-height: 96rpx;
  box-shadow: 0 12rpx 36rpx rgba(235, 47, 150, 0.3);
}

.btn-secondary {
  background: white;
  color: #EB2F96;
  border: 2rpx solid #EB2F96;
  border-radius: 24rpx;
  padding: 32rpx 48rpx;
  font-size: 32rpx;
  min-height: 96rpx;
  box-shadow: 0 4rpx 12rpx rgba(235, 47, 150, 0.15);
}

.card {
  background: white;
  border-radius: 24rpx;
  padding: 32rpx;
  margin: 32rpx;
  box-shadow: 0 12rpx 36rpx rgba(0, 0, 0, 0.15);
}

/* 完成状态样式 */
.btn-completed {
  background: #8B5CF6;
  color: white;
  border-radius: 24rpx;
  padding: 32rpx 48rpx;
  font-size: 32rpx;
  min-height: 96rpx;
  box-shadow: 0 12rpx 36rpx rgba(139, 92, 246, 0.3);
}

/* 警告状态样式 */
.btn-warning {
  background: #FFA940;
  color: white;
  border-radius: 24rpx;
  padding: 32rpx 48rpx;
  font-size: 32rpx;
  min-height: 96rpx;
  box-shadow: 0 12rpx 36rpx rgba(255, 169, 64, 0.3);
}

/* 状态标签 */
.status-completed {
  color: #8B5CF6;
  background: rgba(139, 92, 246, 0.1);
  padding: 8rpx 16rpx;
  border-radius: 16rpx;
  font-size: 24rpx;
}

.status-warning {
  color: #FFA940;
  background: rgba(255, 169, 64, 0.1);
  padding: 8rpx 16rpx;
  border-radius: 16rpx;
  font-size: 24rpx;
}

.status-idle {
  color: #9CA3AF;
  background: rgba(156, 163, 175, 0.1);
  padding: 8rpx 16rpx;
  border-radius: 16rpx;
  font-size: 24rpx;
}

.section-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin: 30rpx 20rpx 20rpx;
}

/* 加载中状态 */
.loading {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 400rpx;
}

.loading text {
  color: #999;
  font-size: 28rpx;
}

/* 空状态 */
.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 40rpx;
  text-align: center;
}

.empty text {
  color: #999;
  font-size: 28rpx;
  margin-top: 20rpx;
}
